		(MessageOrdering "receive" )
		(RoutingSpace "HyperSpace" )
		(Parameter (Name "StarID" )
			(DataType "long" )
			(Cardinality "1" )
			(Description "ID of the star that has left the starfield" )
			(Accuracy "perfect" )
			(AccuracyCondition "always" )
