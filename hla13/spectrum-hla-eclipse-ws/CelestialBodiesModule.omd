	(Class (ID 1)
		(Name "StarField" )
		(PSCapabilities PS )
		(Description "A set of stars that comprise the star field" )
		(Attribute (Name "Stars" )
			(DataType "StarTypeArray" )
			(Cardinality "1" )
			(Description "Starfield star data" )
			(Units "star count" )
			(Resolution "1" )
			(Accuracy "perfect" )
			(AccuracyCondition "perfect" )
			(UpdateType Conditional )
			(UpdateCondition "On change" )
			(TransferAccept N )
			(UpdateReflect UR )
			(DeliveryCategory "best_effort" )
			(MessageOrdering "receive" )
			(RoutingSpace "HyperSpace" )
		)
	)
	(Class (ID 2)
		(Name "SolarSystem" )
		(PSCapabilities PS )
		(Description "A set of planets that comprise the solar system" )
		(Attribute (Name "Planets" )
			(DataType "PlanetTypeArray" )
			(Cardinality "1" )
			(Description "Solar system planet data" )
			(Units "planet count" )
			(Resolution "1" )
			(Accuracy "perfect" )
			(AccuracyCondition "perfect" )
			(UpdateType Conditional )
			(UpdateCondition "On change" )
			(TransferAccept N )
			(UpdateReflect UR )
			(DeliveryCategory "best_effort" )
			(MessageOrdering "receive" )
			(RoutingSpace "HyperSpace" )
		)
	)
	(Interaction (ID 1)
		(Name "StarHasLeftStarField" )
		(ISRType IR )
		(Description "Star has left the starfield" )
